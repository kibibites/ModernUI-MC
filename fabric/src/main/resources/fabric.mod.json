{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${version}",
  "name": "${mod_name}",
  "description": "${description}",
  "authors": [
    "${mod_author}"
  ],
  "contributors": [
    "The Android Open Source Project"
  ],
  "contact": {
    "homepage": "${mod_homepage}",
    "issues": "${issues_url}",
    "sources": "${mod_source}"
  },
  "license": "${license}",
  "icon": "modernui_logo.png",
  "environment": "client",
  "entrypoints": {
    "main": [
      "icyllis.modernui.mc.fabric.ModernUIFabric"
    ],
    "client": [
      "icyllis.modernui.mc.fabric.ModernUIFabricClient"
    ],
    "modmenu": [
      "icyllis.modernui.mc.fabric.MuiModMenuApi"
    ]
  },
  "mixins": [
    "mixins.modernui-fabric.json",
    "mixins.modernui-textmc.json"
  ],
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "minecraft": "~${minecraft_version}",
    "java": ">=${java_version}",
    "fabric-api": ">=${fabric_api_version}",
    "forgeconfigapiport": ">=${forgeconfigapiport_version}"
  },
  "conflicts": {
    "blur": "*",
    "tipthescales": "*"
  }
}